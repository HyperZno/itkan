<%- include('../partials/header', { title: student.name + ' ' + student.surname }) %>
<% currentPage = 'siniflar'; %>

<div class="back" style="margin-bottom:16px">
  <a href="/sinif/<%= student.class_id %>" class="btn btn-s btn-ico"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
  <div><h1 style="font-size:20px;font-weight:700;line-height:1.2"><%= student.name %> <%= student.surname %></h1><span style="font-size:12px;color:var(--text2)"><%= student.class_name %></span></div>
</div>

<div class="card sec">
  <div class="card-hdr"><h2 class="card-title" style="margin:0">Öğrenci Bilgileri</h2><a href="/ogrenci/<%= student.id %>/duzenle" class="btn btn-s btn-sm">Düzenle</a></div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px">
    <div><strong style="color:var(--text2);display:block;font-size:11px;font-weight:600">Ad Soyad</strong><span><%= student.name %> <%= student.surname %></span></div>
    <div><strong style="color:var(--text2);display:block;font-size:11px;font-weight:600">TC Kimlik</strong><span><%= student.tc_kimlik || '-' %></span></div>
    <div><strong style="color:var(--text2);display:block;font-size:11px;font-weight:600">Yaş</strong><span><%= student.age || '-' %></span></div>
    <div><strong style="color:var(--text2);display:block;font-size:11px;font-weight:600">Okul Sınıfı</strong><span><%= student.school_grade || '-' %></span></div>
    <div><strong style="color:var(--text2);display:block;font-size:11px;font-weight:600">Sınıf</strong><span><%= student.class_name %></span></div>
    <div><strong style="color:var(--text2);display:block;font-size:11px;font-weight:600">Veli</strong><span><%= student.parent_name || '-' %></span></div>
    <div><strong style="color:var(--text2);display:block;font-size:11px;font-weight:600">Telefon</strong><span><%= student.phone || '-' %></span></div>
    <div style="grid-column:1/-1"><strong style="color:var(--text2);display:block;font-size:11px;font-weight:600">Adres</strong><span><%= student.address || '-' %></span></div>
  </div>
</div>

<div class="sec">
  <div class="sec-hdr"><h2 class="sec-t">Ödevler</h2><a href="/odev/ogrenci/<%= student.id %>/ekle" class="btn btn-p btn-sm" style="gap:6px">
    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>Ödev Ver
  </a></div>

  <% if (homework.length === 0) { %>
  <div class="card"><div class="empty" style="padding:20px">
    <div class="empty-t" style="font-size:14px">Henüz ödev verilmemiş</div>
    <div class="empty-d">Bu öğrenciye ödev vermek için "Ödev Ver" butonuna tıkla</div>
  </div></div>
  <% } else { %>
  <% homework.forEach(function(h) { %>
  <div class="hwc">
    <div class="hwc-t">
      <div>
        <div class="hwc-s">
          <% if (h.type === 'elifba') { %>
            📖 Elifba <%= h.elifba_topic_text ? '' : (h.lesson_number ? '- ' + h.lesson_number + '. Konu' : '') %>
          <% } else if (h.type === 'ezber') { %>
            📖 Ezber: <%= h.elifba_topic_text %>
          <% } else { %>
            📖 <%= h.surah_name %> Suresi
            <% if (h.translation_option === 'mealiyle') { %>
              <span class="bdg bdg-info" style="font-size: 9px; padding: 1px 4px; margin-left: 4px; display: inline-block;">Mealiyle</span>
            <% } else if (h.translation_option === 'sadece_meal') { %>
              <span class="bdg bdg-warn" style="font-size: 9px; padding: 1px 4px; margin-left: 4px; display: inline-block;">Sadece Meal</span>
            <% } %>
          <% } %>
        </div>
        <div class="hwc-a">
          <% if (h.type === 'elifba') { %>
            <%= h.elifba_topic_text || h.elifba_topic_name || '' %>
            <% if (h.elifba_url) { %>
              <div style="margin-top: 6px;">
                <a href="<%= h.elifba_url %>" target="_blank" class="sec-lk" style="font-size: 11px; font-weight: 700; text-decoration: underline;">Diyanet'te Çalış ➔</a>
              </div>
            <% } %>
          <% } else if (h.type === 'ezber') { %>
            <!-- Ezber is fully described in the title -->
          <% } else { %>
            <%= h.page_number ? 'S. ' + h.page_number + (h.page_detail ? ' (' + h.page_detail + ')' : '') : (h.start_ayah ? h.start_ayah + '-' + h.end_ayah + '. ayetler' : '') %>
          <% } %>
        </div>
      </div>
      <span class="bdg <%= h.status === 'completed' ? 'bdg-ok' : (h.status === 'repeated' ? 'bdg-gray' : (h.status === 'gelmedi' || h.status === 'yapmadi' ? 'bdg-err' : 'bdg-warn')) %>">
        <%= h.status === 'completed' ? (h.type === 'ezber' ? 'Ezberledi' : 'Yaptı') : (h.status === 'repeated' ? 'Tekrar Verildi' : (h.status === 'gelmedi' ? 'Gelmedi' : (h.status === 'yapmadi' ? 'Yapmadı' : 'Çalışıyor'))) %>
      </span>
    </div>
    <div class="hwc-m">
      <span><%= h.teacher_name %> verdi</span>
      <span><%= new Date(h.assigned_date).toLocaleDateString('tr-TR') %></span>
      <% if (h.due_date) { %><span>Teslim: <%= new Date(h.due_date).toLocaleDateString('tr-TR') %></span><% } %>
      <% if (h.checker_name) { %><span>Kontrol: <%= h.checker_name %></span><% } %>
    </div>
    
    <% if (h.status === 'repeated' && h.child_due_date) { %>
      <div style="font-size: 11px; color: #d97706; margin-top: 6px; font-weight: 600; background: #fffbeb; padding: 6px 10px; border-radius: 6px; border: 1px solid #fde68a; display: inline-block; width: fit-content;">
        🔄 Bu ödev <%= new Date(h.child_due_date).toLocaleDateString('tr-TR') %> tarihine tekrar verilmiştir.
      </div>
    <% } %>
    <% if (h.parent_id) { %>
      <div style="font-size: 11px; color: #059669; margin-top: 6px; font-weight: 600; background: #ecfdf5; padding: 6px 10px; border-radius: 6px; border: 1px solid #a7f3d0; display: inline-block; width: fit-content;">
        🔄 Bu ödev, yapmadığı bir önceki ödevin tekrarıdır.
      </div>
    <% } %>

    <% if (h.notes) { %><div class="hwc-n"><%= h.notes %></div><% } %>
    
    <div class="hwc-b" style="display:flex; flex-direction:column; gap:8px;">
      <div style="display:flex; gap:4px; flex-wrap:wrap; width:100%; align-items:center;">
        <form method="POST" action="/odev/<%= h.id %>/guncelle" style="display:flex; gap:4px; flex-wrap:wrap; margin:0;">
          <button type="submit" name="status" value="in_progress" class="st-btn <%= h.status === 'in_progress' ? 's2' : '' %>">Çalışıyor</button>
          <button type="submit" name="status" value="completed" class="st-btn <%= h.status === 'completed' ? 's3' : '' %>">
            <%= h.type === 'ezber' ? 'Ezberledi' : 'Yaptı' %>
          </button>
          <button type="submit" name="status" value="gelmedi" class="st-btn <%= h.status === 'gelmedi' ? 's1' : '' %>" style="background:#fee2e2; color:#ef4444; border-color:#fca5a5;">Gelmedi</button>
          <button type="submit" name="status" value="yapmadi" class="st-btn <%= h.status === 'yapmadi' ? 's1' : '' %>" style="background:#fee2e2; color:#dc2626; border-color:#fca5a5;">Yapmadı</button>
        </form>
        <% if (h.status !== 'repeated') { %>
          <button type="button" class="st-btn" onclick="toggleRepeatForm('<%= h.id %>')" style="background:#fef3c7; color:#d97706; border-color:#fde68a;">Tekrarla</button>
        <% } %>
        <form method="POST" action="/odev/<%= h.id %>/sil" style="margin-left:auto; margin-bottom:0;">
          <button type="submit" class="btn btn-err btn-xs">Sil</button>
        </form>
      </div>

      <!-- Inline Repeat Form -->
      <div id="repeatForm_<%= h.id %>" style="display:none; border-top:1px dashed #cbd5e1; padding-top:8px; margin-top:4px;">
        <form method="POST" action="/odev/<%= h.id %>/tekrarla" style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin:0;">
          <div class="fg" style="margin:0; flex:1; min-width:120px;">
            <label class="fl" style="font-size:10px;">Yeni Teslim Tarihi</label>
            <input type="date" name="due_date" class="fi" style="padding:4px 8px; font-size:12px; height:32px;" required>
          </div>
          <div class="fg" style="margin:0; flex:2; min-width:180px;">
            <label class="fl" style="font-size:10px;">Not (isteğe bağlı)</label>
            <input type="text" name="notes" class="fi" style="padding:4px 8px; font-size:12px; height:32px;" placeholder="Örn: Tekrar ödev">
          </div>
          <div style="display:flex; gap:4px; margin-top:14px;">
            <button type="submit" class="btn btn-p btn-sm" style="padding:4px 10px; font-size:11px;">Tekrarla</button>
            <button type="button" class="btn btn-s btn-sm" style="padding:4px 10px; font-size:11px;" onclick="toggleRepeatForm('<%= h.id %>')">Vazgeç</button>
          </div>
        </form>
      </div>
    </div>
  </div>
  <% }); %>
  <% } %>
</div>

<script>
function toggleRepeatForm(id) {
  var formDiv = document.getElementById('repeatForm_' + id);
  if (formDiv.style.display === 'none') {
    formDiv.style.display = 'block';
  } else {
    formDiv.style.display = 'none';
  }
}
</script>

<%- include('../partials/footer') %>
