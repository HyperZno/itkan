<%- include('partials/header', { title: 'Şifre Değiştir' }) %>
<% currentPage = 'dashboard'; %>

<div class="back" style="margin-bottom:24px">
  <a href="/dashboard" class="btn btn-s btn-ico" aria-label="Geri">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  </a>
  <div>
    <h1 style="font-size:22px;font-weight:800;line-height:1.2">Şifre Değiştir</h1>
    <span style="font-size:12px;color:var(--text2);font-weight:600">Hesap güvenliğiniz için şifrenizi güncelleyin</span>
  </div>
</div>

<div class="card">
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-err"><%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-ok"><%= success %></div>
  <% } %>

  <% if (canChange) { %>
  <form method="POST" action="/sifre-degistir">
    <div class="fg">
      <label class="fl">Mevcut Şifre</label>
      <input type="password" name="current_password" class="fi" placeholder="Mevcut şifreniz" required>
    </div>
    <div class="fg">
      <label class="fl">Yeni Şifre</label>
      <input type="password" name="new_password" class="fi" placeholder="En az 6 karakter giriniz" minlength="6" required>
    </div>
    <div class="fg">
      <label class="fl">Yeni Şifre (Tekrar)</label>
      <input type="password" name="confirm_password" class="fi" placeholder="Yeni şifreyi tekrar yazın" minlength="6" required>
    </div>
    <button type="submit" class="btn btn-p btn-blk">Şifreyi Güncelle</button>
  </form>
  <% } else { %>
  <div style="text-align: center; padding: 24px 0;">
    <div class="empty-ico" style="background: var(--warn-bg); border-color: rgba(245, 158, 11, 0.2)">
      <svg style="color: var(--warn)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
    </div>
    <p style="font-size: 14px; font-weight: 700; color: var(--text2); margin-top: 12px; line-height: 1.6;">
      Şifre değiştirme hakkınızı kullandınız.<br>
      Tekrar şifre değişimi yapmak için lütfen Süper Admin ile iletişime geçin.
    </p>
    <a href="/dashboard" class="btn btn-s btn-sm" style="margin-top: 20px;">Ana Sayfaya Dön</a>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
