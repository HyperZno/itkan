<%- include('../partials/header', { title: 'Yoklama Geçmişi' }) %>
<% currentPage = 'siniflar'; %>

<div class="back" style="margin-bottom:24px">
  <a href="/yoklama/sinif/<%= classData.id %>" class="btn btn-s btn-ico"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
  <div>
    <h1 style="font-size:20px;font-weight:800;line-height:1.2">Yoklama Geçmişi</h1>
    <span style="font-size:12px;color:var(--text2);font-weight:500"><%= classData.name %></span>
  </div>
</div>

<% if (sessions.length === 0) { %>
<div class="card">
  <div class="empty">
    <div class="empty-t">Yoklama Bulunamadı</div>
    <div class="empty-d">Bu sınıfa ait geçmiş bir yoklama kaydı bulunmuyor.</div>
  </div>
</div>
<% } else { %>
<div class="lst">
  <% sessions.forEach(function(s) { %>
  <a href="/yoklama/detay/<%= s.id %>" class="lst-it" style="text-decoration: none; padding: 16px 20px; border: 1px solid var(--border); margin-bottom: 8px; transition: all 0.2s;">
    <div class="lst-c">
      <div class="lst-t" style="font-size:14px; font-weight:700; color: var(--text);">
        <%= new Date(s.date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric', weekday: 'long' }) %>
      </div>
      <div style="font-size:11px; color:var(--text2); margin-top:4px;">
        Öğretmen: <%= s.teacher_name %>
      </div>
    </div>
    <div class="lst-r" style="gap:8px">
      <span class="bdg bdg-ok"><%= s.present_count %> Burada</span>
      <span class="bdg bdg-err"><%= s.absent_count %> Yok</span>
      <svg style="color: var(--text3); width: 18px; height: 18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </div>
  </a>
  <% }); %>
</div>
<% } %>

<%- include('../partials/footer') %>
