<%- include('../partials/header', { title: 'Yoklama Takvimi' }) %>
<% currentPage = 'siniflar'; %>

<div class="back" style="margin-bottom:24px">
  <a href="/sinif/<%= classData.id %>" class="btn btn-s btn-ico"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
  <div>
    <h1 style="font-size:20px;font-weight:800;line-height:1.2">Yoklama Takvimi</h1>
    <span style="font-size:12px;color:var(--text2);font-weight:500"><%= classData.name %></span>
  </div>
</div>

<div class="card" style="padding: 20px 24px;">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
    <button onclick="prevMonth()" class="btn btn-s btn-ico">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 18px; height: 18px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <h2 id="calendarTitle" style="font-size: 16px; font-weight: 800; color: var(--text); margin: 0;"></h2>
    <button onclick="nextMonth()" class="btn btn-s btn-ico">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 18px; height: 18px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>

  <!-- Calendar Grid Header -->
  <div style="display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; gap: 8px; font-weight: 700; font-size: 12px; color: var(--text2); margin-bottom: 12px; border-bottom: 1px solid var(--border); padding-bottom: 8px;">
    <div>Pt</div><div>Sa</div><div>Ça</div><div>Pe</div><div>Cu</div><div>Ct</div><div>Pz</div>
  </div>
  
  <!-- Calendar Days Grid -->
  <div id="calendarDays" style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px;">
    <!-- Days dynamically loaded -->
  </div>
</div>

<div class="card" style="padding: 20px;">
  <div class="card-hdr" style="margin-bottom: 12px;">
    <h3 class="card-title" style="margin: 0; font-size: 14px; display: flex; align-items: center; gap: 8px;">
      <svg style="width: 18px; height: 18px; color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Yardım ve Bilgi
    </h3>
  </div>
  <div style="font-size: 13px; color: var(--text2); line-height: 1.6;">
    <p>• Yoklama almak veya düzenlemek istediğiniz güne takvim üzerinden dokunarak işlem yapabilirsiniz.</p>
    <p style="margin-top: 6px;">• Yeşil nokta (<span style="display: inline-block; width: 8px; height: 8px; background: var(--ok); border-radius: 50%; vertical-align: middle;"></span>) simgesi, o günün yoklamasının başarıyla kaydedildiğini gösterir.</p>
  </div>
</div>

<script>
const activeDates = new Set(<%- JSON.stringify(sessionDates) %>);
const classId = <%= classData.id %>;
let currentDate = new Date();

function renderCalendar() {
  const year = currentDate.getFullYear();
  const month = currentDate.getMonth();
  
  const monthNames = ["Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık"];
  document.getElementById('calendarTitle').textContent = monthNames[month] + " " + year;
  
  // First day of month
  const firstDayIndex = (new Date(year, month, 1).getDay() + 6) % 7;
  const lastDay = new Date(year, month + 1, 0).getDate();
  const prevLastDay = new Date(year, month, 0).getDate();
  
  let daysHTML = '';
  
  // Prev month empty slots
  for (let x = firstDayIndex; x > 0; x--) {
    daysHTML += `<div style="padding: 12px 4px; color: var(--text3); font-size: 13px; text-align: center; opacity: 0.3;">${prevLastDay - x + 1}</div>`;
  }
  
  // Current month days
  for (let i = 1; i <= lastDay; i++) {
    const formattedDate = `${year}-${String(month + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
    const hasSession = activeDates.has(formattedDate);
    
    // Highlight today
    const isToday = new Date().toDateString() === new Date(year, month, i).toDateString();
    
    daysHTML += `
      <a href="/yoklama/sinif/${classId}/tarih/${formattedDate}" 
         style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 48px; padding: 6px 4px; border-radius: var(--r-sm); border: 1px solid ${isToday ? 'var(--primary)' : 'var(--border)'}; background: ${isToday ? 'var(--primary-light)' : '#ffffff'}; text-decoration: none; color: var(--text); position: relative; transition: all 0.2s;"
         class="calendar-day-btn">
        <span style="font-size: 13px; font-weight: 700; color: ${isToday ? 'var(--primary)' : 'var(--text)'};">${i}</span>
        ${hasSession ? '<span style="width: 6px; height: 6px; background: var(--ok); border-radius: 50%; margin-top: 4px; box-shadow: 0 0 4px var(--ok)"></span>' : ''}
      </a>
    `;
  }
  
  document.getElementById('calendarDays').innerHTML = daysHTML;
}

function prevMonth() {
  currentDate.setMonth(currentDate.getMonth() - 1);
  renderCalendar();
}

function nextMonth() {
  currentDate.setMonth(currentDate.getMonth() + 1);
  renderCalendar();
}

renderCalendar();
</script>

<style>
.calendar-day-btn:hover {
  background: var(--primary-light) !important;
  border-color: var(--primary) !important;
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}
</style>

<%- include('../partials/footer') %>
