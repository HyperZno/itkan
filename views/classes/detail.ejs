<%- include('../partials/header', { title: classData.name }) %>
<% currentPage = 'siniflar'; %>

<div class="back" style="margin-bottom:16px">
  <a href="/siniflar" class="btn btn-s btn-ico"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
  <div><h1 style="font-size:20px;font-weight:700;line-height:1.2"><%= classData.name %></h1><span style="font-size:12px;color:var(--text2);font-weight:500"><%= students.length %> öğrenci</span></div>
</div>

<div class="act">
  <a href="/yoklama/sinif/<%= classData.id %>" class="act-c">
    <svg fill="none" stroke="#0a6e6a" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span style="color:#0a6e6a">Yoklama</span>
  </a>
  <a href="/notlar/sinif/<%= classData.id %>" class="act-c">
    <svg fill="none" stroke="#d97706" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
    <span style="color:#d97706">Notlar</span>
  </a>
  <a href="/yoklama/gecmis/sinif/<%= classData.id %>" class="act-c">
    <svg fill="none" stroke="#6b7280" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span style="color:#6b7280">Geçmiş</span>
  </a>
</div>

<div class="card sec">
  <div class="card-hdr">
    <h2 class="card-title" style="margin:0">Öğrenciler</h2>
    <div style="display: flex; gap: 8px;">
      <button onclick="toggleAddStudentForm()" class="btn btn-p btn-sm" style="gap:6px">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Öğrenci Ekle
      </button>
    </div>
  </div>

  <!-- Collapsible Add Student Form -->
  <div id="addStudentCollapse" style="display: none; border-bottom: 1px dashed var(--border); padding-bottom: 20px; margin-bottom: 20px; animation: slideUp 0.2s ease;">
    <h3 style="font-size: 14px; font-weight: 700; margin-bottom: 12px; color: var(--primary);">Yeni Öğrenci Ekle</h3>
    <form method="POST" action="/sinif/<%= classData.id %>/ogrenci-ekle">
      <div class="flex-2">
        <div class="fg">
          <label class="fl">Ad Soyad (Alt alta çoklu ekleyebilirsiniz) *</label>
          <textarea name="name" class="fta" style="min-height: 80px;" placeholder="Ad Soyad&#10;Ad Soyad" required autocomplete="off"></textarea>
        </div>
        <div class="fg">
          <label class="fl">Okul Sınıfı</label>
          <select name="school_grade" class="fs">
            <option value="">Seçiniz...</option>
            <% for(var i=1; i<=12; i++) { %>
            <option value="<%= i %>. Sınıf"><%= i %>. Sınıf</option>
            <% } %>
            <option value="Yok / Mezun">Yok / Mezun</option>
          </select>
        </div>
      </div>
      
      <div class="flex-3">
        <div class="fg">
          <label class="fl">TC Kimlik Numarası</label>
          <input type="text" name="tc_kimlik" class="fi" placeholder="11 hane" maxlength="11" autocomplete="off">
        </div>
        <div class="fg">
          <label class="fl">Yaş</label>
          <input type="number" name="age" class="fi" placeholder="Yaş" min="1" max="99">
        </div>
        <div class="fg">
          <label class="fl">Veli Adı Soyadı</label>
          <input type="text" name="parent_name" class="fi" placeholder="Veli" autocomplete="off">
        </div>
      </div>
      
      <div class="flex-2">
        <div class="fg">
          <label class="fl">Telefon</label>
          <input type="tel" name="phone" class="fi" placeholder="Telefon">
        </div>
        <div class="fg">
          <label class="fl">Ev Adresi</label>
          <input type="text" name="address" class="fi" placeholder="Adres">
        </div>
      </div>
      
      <div class="flex-gap" style="justify-content: flex-end; margin-top: 8px;">
        <button type="button" class="btn btn-s btn-sm" onclick="toggleAddStudentForm()">Vazgeç</button>
        <button type="submit" class="btn btn-p btn-sm">Kaydet</button>
      </div>
    </form>
  </div>

  <!-- Arama Çubuğu -->
  <% if (students.length > 0) { %>
  <div class="fg" style="margin-top: 12px; margin-bottom: 16px;">
    <input type="text" id="studentSearchInput" class="fi" placeholder="Sınıfta öğrenci ara..." oninput="filterStudents()">
  </div>
  <% } %>

  <% if (students.length === 0) { %>
  <div class="empty" style="padding:20px 0"><p style="font-size:13px;color:var(--text3)">Henüz öğrenci eklenmemiş</p></div>
  <% } else { %>
  <div style="margin:0 -4px" id="studentsContainer">
    <% students.forEach(function(s, i) { %>
    <div class="lst-it student-item" data-name="<%= s.name.toLowerCase() %> <%= s.surname.toLowerCase() %>" style="padding:12px 4px;cursor:default;border-bottom:1px solid rgba(226, 232, 240, 0.5)">
      <div class="lst-av" style="width:36px;height:36px;font-size:13px;background:#f3f4f6;color:var(--text2)"><%= s.name.charAt(0) %></div>
      <div class="lst-c">
        <div class="lst-t" style="font-size:13px"><%= s.name %> <%= s.surname %></div>
        <div class="lst-s" style="font-size:11px">
          <%= s.parent_name ? s.parent_name + ' • ' : '' %><%= s.phone ? s.phone : '' %>
          <%= s.tc_kimlik ? ' • TC: ' + s.tc_kimlik : '' %>
          <%= s.school_grade ? ' • Okul: ' + s.school_grade : '' %>
        </div>
      </div>
      <div class="lst-r">
        <a href="/ogrenci/<%= s.id %>" class="btn btn-xs btn-s">Detay</a>
        <form method="POST" action="/ogrenci/<%= s.id %>/sil" style="margin:0">
          <button type="submit" class="btn btn-xs btn-err">Sil</button>
        </form>
      </div>
    </div>
    <% }); %>
  </div>
  <% } %>
</div>

<% if (notes.length > 0) { %>
<div class="sec">
  <div class="sec-hdr"><h2 class="sec-t">Son Notlar</h2><a href="/notlar/sinif/<%= classData.id %>" class="sec-lk">Tümü</a></div>
  <% notes.forEach(function(n) { %>
  <div class="nc">
    <div class="nc-hdr"><span class="nc-auth"><%= n.teacher_name %></span><span class="nc-date"><%= new Date(n.created_at).toLocaleDateString('tr-TR') %></span></div>
    <div class="nc-c"><%= n.content.length > 120 ? n.content.substring(0,120)+'...' : n.content %></div>
  </div>
  <% }); %>
</div>
<% } %>

<div style="margin-top:24px;text-align:center">
  <form method="POST" action="/sinif/<%= classData.id %>/sil">
    <button type="submit" class="btn btn-err btn-sm">Sınıfı Sil</button>
  </form>
</div>

<script>
function toggleAddStudentForm() {
  var formDiv = document.getElementById('addStudentCollapse');
  if (formDiv.style.display === 'none') {
    formDiv.style.display = 'block';
  } else {
    formDiv.style.display = 'none';
  }
}

function filterStudents() {
  var input = document.getElementById('studentSearchInput').value.toLowerCase();
  var items = document.querySelectorAll('.student-item');
  items.forEach(function(item) {
    var name = item.dataset.name;
    if (name.indexOf(input) > -1) {
      item.style.display = 'flex';
    } else {
      item.style.display = 'none';
    }
  });
}
</script>

<%- include('../partials/footer') %>
