<%- include('../partials/header', { title: 'Duyurular' }) %>
<% currentPage = 'duyurular'; %>

<div class="hdr">
  <h1>Genel Duyurular</h1>
  <span class="hdr-sub"><%= announcements.length %> duyuru yayınlandı</span>
</div>

<!-- Publish Announcement Form (Teachers & Admins Only) -->
<div class="card" style="margin-bottom: 20px;">
  <div class="card-hdr" style="margin-bottom: 12px; cursor: pointer; user-select: none;" onclick="togglePublishForm()">
    <h2 class="card-title" style="margin: 0; display: flex; align-items: center; gap: 8px;">
      <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      Yeni Duyuru Yayınla
    </h2>
    <span id="formToggleIcon" style="font-weight: 700; color: var(--primary);">[+] Göster</span>
  </div>
  
  <form method="POST" action="/duyurular/yayinla" id="publishForm" style="display: none; margin-top: 16px;">
    <div class="fg">
      <label>Duyuru Başlığı</label>
      <input type="text" name="title" class="fi" placeholder="Duyuru başlığını girin" required autocomplete="off">
    </div>
    
    <div class="fg" style="margin-bottom: 16px;">
      <label>Duyuru İçeriği</label>
      <textarea name="content" class="fi" style="height: 120px; resize: none; font-family: inherit;" placeholder="Tüm öğretmenlere ve sisteme duyurmak istediğiniz metni yazın..." required></textarea>
    </div>

    <!-- Recipient list -->
    <% if (typeof teachers !== 'undefined' && teachers.length > 0) { %>
      <div class="fg" style="margin-bottom: 16px;">
        <label style="font-weight: 700; font-size: 13px; color: var(--text2); display: block; margin-bottom: 6px;">Duyurunun Gönderileceği Alıcılar (<%= teachers.length %>)</label>
        <div style="display: flex; gap: 6px; flex-wrap: wrap; max-height: 100px; overflow-y: auto; background: #f8fafc; border: 1px solid var(--border); padding: 10px; border-radius: 8px;">
          <% teachers.forEach(function(t) { %>
            <span class="bdg bdg-gray" style="font-size: 11px; padding: 4px 8px; color: var(--text2); display: inline-flex; align-items: center; gap: 4px;">
              👤 <%= t.display_name %> (<%= t.role === 'super_admin' ? 'Yönetici' : 'Öğretmen' %>)
            </span>
          <% }); %>
        </div>
      </div>
    <% } %>
    
    <button type="submit" class="btn btn-p btn-blk" style="font-weight: 800;">Duyuruyu Yayınla (Bildirim Gönder)</button>
  </form>
</div>

<!-- Announcements Feed -->
<div class="lst">
  <% if (announcements.length === 0) { %>
    <div class="card">
      <div class="empty">
        <div class="empty-ico">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </div>
        <div class="empty-t">Duyuru Bulunmamaktadır</div>
        <div class="empty-d">Henüz genel bir duyuru yayınlanmadı.</div>
      </div>
    </div>
  <% } else { %>
    <% announcements.forEach(function(a) { %>
      <div class="card" style="margin-bottom: 16px; border-left: 5px solid var(--primary);">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 8px; margin-bottom: 8px;">
          <h3 style="font-size: 15px; font-weight: 800; color: var(--text); margin: 0;"><%= a.title %></h3>
          <span style="font-size: 11px; color: var(--text3); font-weight: 500;">
            <%= new Date(a.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
          </span>
        </div>
        <div style="font-size: 13px; color: var(--text2); line-height: 1.5; white-space: pre-line; margin-bottom: 12px;">
          <%= a.content %>
        </div>
        <div style="border-top: 1px solid #f1f5f9; padding-top: 8px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;">
          <span style="font-size: 11px; color: var(--text3); font-weight: 600;">Yayınlayan: <%= a.author_name %></span>
          <div style="display: flex; gap: 8px; align-items: center;">
            <% if (currentUser && (currentUser.role === 'super_admin' || currentUser.id === a.created_by)) { %>
              <form method="POST" action="/duyurular/sil/<%= a.id %>" style="margin: 0;" onsubmit="return confirm('Bu duyuruyu silmek istediğinize emin misiniz?');">
                <button type="submit" class="btn btn-err btn-xs" style="padding: 3px 8px; font-size: 10px; font-weight: 700;">Sil</button>
              </form>
            <% } %>
            <span class="bdg bdg-ok" style="font-size: 9px; padding: 2px 6px;">Sistem Bildirimi</span>
          </div>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>

<script>
function togglePublishForm() {
  var form = document.getElementById('publishForm');
  var txt = document.getElementById('formToggleIcon');
  if (form.style.display === 'none') {
    form.style.display = 'block';
    txt.textContent = '[-] Gizle';
  } else {
    form.style.display = 'none';
    txt.textContent = '[+] Göster';
  }
}
</script>

<%- include('../partials/footer') %>
