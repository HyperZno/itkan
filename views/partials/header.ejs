<!-- Automatic Announcement Popup Modal -->
<div id="autoAnnouncementModal" class="dev-modal" style="display: none; align-items: center; justify-content: center; z-index: 130;">
  <div class="dev-modal-content" style="max-width: 480px; width: 90%; margin: auto; animation: slideUp 0.3s ease; border-top: 5px solid var(--primary); background: #ffffff; border: 1px solid var(--border); box-shadow: var(--shadow-lg); border-radius: 16px; padding: 20px;">
    <div class="dev-modal-header" style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px; margin-bottom: 16px;">
      <h3 style="display: flex; align-items: center; gap: 8px; font-size: 16px; font-weight: 800; color: var(--text); margin: 0;">
        📢 Yeni Duyuru
      </h3>
      <button class="dev-close-btn" onclick="closeAutoAnnouncementModal()" style="border: none; background: none; font-size: 20px; cursor: pointer; color: var(--text3);">&times;</button>
    </div>
    <div class="dev-modal-body" style="text-align: left;">
      <h4 id="autoAnnouncementTitle" style="font-weight: 700; font-size: 15px; color: var(--text); margin-top: 0; margin-bottom: 8px;"></h4>
      <p id="autoAnnouncementContent" style="font-size: 13px; color: var(--text2); line-height: 1.6; white-space: pre-line; margin-bottom: 20px; max-height: 250px; overflow-y: auto; padding-right: 8px; border-bottom: 1px solid #f1f5f9; padding-bottom: 16px;"></p>
      <div style="display: flex; justify-content: space-between; align-items: center; font-size: 11px; color: var(--text3); margin-top: 12px;">
        <span id="autoAnnouncementAuthor" style="font-weight: 600;"></span>
        <button onclick="closeAutoAnnouncementModal()" class="btn btn-p btn-sm" style="padding: 6px 16px; font-size: 12px; font-weight: 700; border-radius: 8px;">Tamam</button>
      </div>
    </div>
  </div>
</div>

<div class="main"><div class="wrap">
<% } %>
