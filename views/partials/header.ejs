<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>İTKAN - <%= typeof title !== 'undefined' ? title : 'Sınıf Yönetimi' %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="icon" type="image/png" href="/logo.png">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<% if (typeof currentUser !== 'undefined' && currentUser) { %>
<% if (typeof currentPage === 'undefined') currentPage = ''; %>

<div class="sidebar" id="sidebar">
  <div class="sidebar-brand">İTKAN <span class="tag">DOCK</span></div>
  <nav class="sidebar-nav">
    <% (locals.navItems || []).forEach(function(item) { %>
    <a href="<%= item.href %>" class="<%= currentPage === item.href.split('/')[1] ? 'active' : '' %>">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item.icon %>"/></svg>
      <%= item.label %>
    </a>
    <% }); %>
    <div style="border-top: 1px solid rgba(255, 255, 255, 0.15); margin: 12px 16px;"></div>
    <a href="#" onclick="openDeveloperModal(event)" style="opacity: 0.85;">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Yapımcı Hakkında
    </a>
  </nav>
  <div class="sidebar-footer">
    <div class="profile-container">
      <button class="profile-btn" onclick="toggleProfileDropdown(event, 'sidebarDropdown')">
        <div class="profile-avatar"><%= currentUser.display_name.charAt(0).toUpperCase() %></div>
        <div class="profile-info">
          <span class="profile-name"><%= currentUser.display_name %></span>
          <span class="profile-role"><%= currentUser.role === 'super_admin' ? 'Yönetici' : 'Öğretmen' %></span>
        </div>
        <svg class="profile-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="profile-dropdown" id="sidebarDropdown">
        <div class="dropdown-header">
          <div class="dropdown-avatar"><%= currentUser.display_name.charAt(0).toUpperCase() %></div>
          <div>
            <div class="dropdown-name"><%= currentUser.display_name %></div>
            <div class="dropdown-username">@<%= currentUser.username %></div>
          </div>
        </div>
        <div class="dropdown-divider"></div>
        <a href="/sifre-degistir" class="dropdown-item" style="color: rgba(255, 255, 255, 0.7); margin-bottom: 4px;">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Şifre Değiştir
        </a>
        <a href="/cikis" class="dropdown-item logout-link">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Çıkış Yap
        </a>
      </div>
    </div>
  </div>
</div>
<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<header class="topbar">
  <div class="topbar-l">
    <button class="mbtn" onclick="toggleSidebar()" aria-label="Menü">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    <a href="/dashboard" class="topbar-brand">İTKAN</a>
  </div>
  <div style="display: flex; align-items: center; gap: 12px; margin-left: auto;">
    <!-- Notification Bell -->
    <div class="profile-container" style="position: relative; width: auto;">
      <button class="bell-btn" onclick="toggleAnnouncementDropdown(event)" style="position: relative; display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; color: var(--text2); transition: all 0.2s; border: none; background: none; cursor: pointer; padding: 0;" aria-label="Bildirimler">
        <svg style="width: 22px; height: 22px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        <span id="bellBadge" style="display: none; position: absolute; top: 4px; right: 4px; width: 8px; height: 8px; border-radius: 50%; background: #ef4444; border: 1px solid #ffffff;"></span>
      </button>
      <div class="profile-dropdown mobile-dropdown-pos" id="bellDropdown" style="width: 280px; padding: 0; max-height: 360px; display: none; flex-direction: column;">
        <div style="padding: 12px; font-weight: 800; font-size: 13px; color: var(--text); border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between;">
          <span>Duyurular</span>
          <span class="bdg bdg-info" style="font-size: 9px; padding: 2px 6px;">Son</span>
        </div>
        <div id="bellDropdownContent" style="overflow-y: auto; max-height: 240px; padding: 8px 0; display: flex; flex-direction: column;">
          <div style="padding: 16px; text-align: center; font-size: 12px; color: var(--text3);">Yükleniyor...</div>
        </div>
        <a href="/duyurular" style="display: block; text-align: center; padding: 10px; font-size: 11px; font-weight: 700; color: var(--primary); border-top: 1px solid #f1f5f9; background: #f8fafc; border-bottom-left-radius: 16px; border-bottom-right-radius: 16px; text-decoration: underline;">Tümünü Gör</a>
      </div>
    </div>

    <div class="profile-container" style="width: auto;">
      <button class="profile-btn-mobile" onclick="toggleProfileDropdown(event, 'mobileDropdown')">
        <%= currentUser.display_name.charAt(0).toUpperCase() %>
      </button>
      <div class="profile-dropdown mobile-dropdown-pos" id="mobileDropdown">
        <div class="dropdown-header">
          <div class="dropdown-avatar"><%= currentUser.display_name.charAt(0).toUpperCase() %></div>
          <div>
            <div class="dropdown-name"><%= currentUser.display_name %></div>
            <div class="dropdown-username">@<%= currentUser.username %></div>
          </div>
        </div>
        <div class="dropdown-divider"></div>
        <a href="/sifre-degistir" class="dropdown-item" style="color: var(--text2); margin-bottom: 4px;">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Şifre Değiştir
        </a>
        <a href="/cikis" class="dropdown-item logout-link">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Çıkış Yap
        </a>
        <div class="dropdown-divider"></div>
        <a href="#" onclick="openDeveloperModal(event)" class="dropdown-item" style="color: var(--text2); margin-bottom: 4px;">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Yapımcı Hakkında
        </a>
      </div>
    </div>
  </div>
</header>

<script>
function toggleProfileDropdown(event, id) {
  event.stopPropagation();
  var dropdown = document.getElementById(id);
  var isOpen = dropdown.classList.contains('show');
  
  // Close all other profile dropdowns and bell dropdown first
  document.querySelectorAll('.profile-dropdown').forEach(function(el) {
    el.classList.remove('show');
    el.style.display = 'none';
  });
  
  if (!isOpen) {
    dropdown.classList.add('show');
    dropdown.style.display = 'block';
  }
}

function toggleAnnouncementDropdown(event) {
  event.stopPropagation();
  var dropdown = document.getElementById('bellDropdown');
  var isOpen = dropdown.classList.contains('show');
  
  // Close all other dropdowns
  document.querySelectorAll('.profile-dropdown').forEach(function(el) {
    el.classList.remove('show');
    el.style.display = 'none';
  });
  
  if (!isOpen) {
    dropdown.classList.add('show');
    dropdown.style.display = 'flex';
    loadAnnouncementDropdown();
  }
}

function loadAnnouncementDropdown() {
  var content = document.getElementById('bellDropdownContent');
  content.innerHTML = '<div style="padding: 16px; text-align: center; font-size: 12px; color: var(--text3);">Yükleniyor...</div>';
  
  fetch('/api/duyurular/liste')
    .then(function(res) { return res.json(); })
    .then(function(list) {
      if (!list || list.length === 0) {
        content.innerHTML = '<div style="padding: 16px; text-align: center; font-size: 12px; color: var(--text3);">Duyuru bulunmamaktadır.</div>';
        return;
      }
      
      var html = '';
      var latestId = list[0].id.toString();
      localStorage.setItem('last_announcement_id', latestId);
      var badge = document.getElementById('bellBadge');
      if (badge) badge.style.display = 'none';

      list.forEach(function(a) {
        var dateStr = new Date(a.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
        html += '<div style="padding: 12px; border-bottom: 1px solid #f8fafc; display: flex; flex-direction: column; gap: 4px; cursor: pointer; text-align: left;" onclick="window.location.href=\'/duyurular\'">' +
                  '<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">' +
                    '<span style="font-size: 12px; font-weight: 700; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 170px;">' + escapeHtml(a.title) + '</span>' +
                    '<span style="font-size: 10px; color: var(--text3); font-weight: 500; flex-shrink: 0;">' + dateStr + '</span>' +
                  '</div>' +
                  '<div style="font-size: 11px; color: var(--text2); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">' + escapeHtml(a.content) + '</div>' +
                  '<div style="font-size: 9px; color: var(--text3); font-weight: 600; text-align: right; margin-top: 2px;">' + escapeHtml(a.author_name) + '</div>' +
                '</div>';
      });
      content.innerHTML = html;
    })
    .catch(function(err) {
      console.error(err);
      content.innerHTML = '<div style="padding: 16px; text-align: center; font-size: 12px; color: var(--err);">Yüklenirken hata oluştu.</div>';
    });
}

function escapeHtml(text) {
  if (!text) return '';
  return text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

// Close dropdowns when clicking anywhere outside
document.addEventListener('click', function(event) {
  if (!event.target.closest('.profile-container')) {
    document.querySelectorAll('.profile-dropdown').forEach(function(el) {
      el.classList.remove('show');
      el.style.display = 'none';
    });
  }
});

function openDeveloperModal(event) {
  if (event) event.preventDefault();
  document.getElementById('developerModal').classList.add('show');
  
  // Close any open profile dropdowns
  document.querySelectorAll('.profile-dropdown').forEach(function(el) {
    el.classList.remove('show');
  });
}
function closeDeveloperModal() {
  document.getElementById('developerModal').classList.remove('show');
}
window.addEventListener('click', function(event) {
  var modal = document.getElementById('developerModal');
  if (event.target === modal) {
    closeDeveloperModal();
  }
});

// HTML5 Notification and Announcement Sync
document.addEventListener('DOMContentLoaded', function() {
  if (typeof Notification !== 'undefined') {
    if (Notification.permission === 'default') {
      Notification.requestPermission();
    }
    checkNewAnnouncements();
  }
});

function checkNewAnnouncements() {
  fetch('/api/duyurular/son')
    .then(function(res) { return res.json(); })
    .then(function(announcement) {
      if (!announcement) return;
      
      var lastReadId = localStorage.getItem('last_announcement_id');
      var badge = document.getElementById('bellBadge');
      
      if (lastReadId !== announcement.id.toString()) {
        if (badge) badge.style.display = 'block';
        
        // Show auto-popup only if not currently on the Announcements page
        if (window.location.pathname !== '/duyurular') {
          showAutoAnnouncement(announcement);
        } else {
          localStorage.setItem('last_announcement_id', announcement.id.toString());
          if (badge) badge.style.display = 'none';
        }
        
        if (Notification.permission === 'granted' && document.visibilityState !== 'visible') {
          var notification = new Notification(announcement.title, {
            body: announcement.content,
            icon: '/logo.png'
          });
          notification.onclick = function() {
            window.focus();
            window.location.href = '/duyurular';
          };
        }
      } else {
        if (window.location.pathname === '/duyurular' && badge) {
          badge.style.display = 'none';
        }
      }
    })
    .catch(function(err) {
      console.error('Error fetching announcements:', err);
    });
}

function showAutoAnnouncement(a) {
  document.getElementById('autoAnnouncementTitle').textContent = a.title;
  document.getElementById('autoAnnouncementContent').textContent = a.content;
  document.getElementById('autoAnnouncementAuthor').textContent = 'Yayınlayan: ' + a.author_name;
  
  var modal = document.getElementById('autoAnnouncementModal');
  modal.style.display = 'flex';
  
  // Set localStorage read status so it only pops up once
  localStorage.setItem('last_announcement_id', a.id.toString());
  var badge = document.getElementById('bellBadge');
  if (badge) badge.style.display = 'none';
}

function closeAutoAnnouncementModal() {
  document.getElementById('autoAnnouncementModal').style.display = 'none';
}

window.addEventListener('click', function(event) {
  var modal = document.getElementById('autoAnnouncementModal');
  if (event.target === modal) {
    closeAutoAnnouncementModal();
  }
});
</script>

