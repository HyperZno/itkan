<% if (typeof currentUser !== 'undefined' && currentUser) { %>
</div></div>

<nav class="bnav">
  <% (locals.navItems || []).filter(function(item) {
       return item.href !== '/sureler';
     }).forEach(function(item) { %>
  <a href="<%= item.href %>" class="<%= currentPage === item.href.split('/')[1] ? 'on' : '' %>">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item.icon %>"/></svg>
    <span><%= item.label %></span>
  </a>
  <% }); %>
</nav>

<script>
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');document.getElementById('sidebarOverlay').classList.toggle('show')}
</script>
<% } %>
</body>
</html>
