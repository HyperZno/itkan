<%- include('../partials/header', { title: 'Öğretmen Düzenle' }) %>
<% currentPage = 'admin'; %>

<div class="back" style="margin-bottom:24px">
  <a href="/admin" class="btn btn-s btn-ico"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
  <div>
    <h1 style="font-size:20px;font-weight:800;line-height:1.2">Öğretmen Düzenle</h1>
    <span style="font-size:12px;color:var(--text2);font-weight:500">Yönetim Paneli</span>
  </div>
</div>

<div class="card">
  <% if (error) { %>
    <div class="alert alert-err" style="margin-bottom: 20px;"><%= error %></div>
  <% } %>

  <form method="POST" action="/admin/ogretmen/<%= teacher.id %>/duzenle">
    <div class="fg">
      <label>Ad Soyad</label>
      <input type="text" name="display_name" class="fi" value="<%= teacher.display_name %>" required placeholder="Öğretmenin adını soyadını yazın" autocomplete="off">
    </div>

    <div class="fg">
      <label>Kullanıcı Adı</label>
      <input type="text" name="username" class="fi" value="<%= teacher.username %>" required placeholder="Giriş için kullanılacak kullanıcı adı" autocomplete="off">
    </div>

    <div class="fg">
      <label>Şifre</label>
      <input type="password" name="password" class="fi" placeholder="Şifreyi değiştirmek istemiyorsanız boş bırakın" minlength="6" autocomplete="new-password">
    </div>

    <div class="fg">
      <label>Kullanıcı Rolü</label>
      <select name="role" class="fi" style="appearance: none; background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23475569%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22%3E%3Cpath d=%22M6 9l6 6 6-6%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 14px center; background-size: 16px;">
        <option value="admin" <%= teacher.role === 'admin' ? 'selected' : '' %>>Öğretmen / Admin</option>
        <option value="super_admin" <%= teacher.role === 'super_admin' ? 'selected' : '' %>>Süper Admin</option>
      </select>
    </div>

    <button type="submit" class="btn btn-p btn-blk" style="font-weight: 800; font-size: 15px; margin-top: 24px;">Değişiklikleri Kaydet</button>
  </form>
</div>

<%- include('../partials/footer') %>
