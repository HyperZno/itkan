<%- include('../partials/header', { title: 'Genel Raporlar' }) %>
<% currentPage = 'admin'; %>

<div class="back" style="margin-bottom:24px">
  <a href="/admin" class="btn btn-s btn-ico"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
  <div>
    <h1 style="font-size:20px;font-weight:800;line-height:1.2">Genel Raporlar</h1>
    <span style="font-size:12px;color:var(--text2);font-weight:500">Sistem Geneli Veri ve Başarı Analizi</span>
  </div>
</div>

<!-- General System Metrics -->
<div class="stats" style="margin-bottom: 24px;">
  <div class="stat">
    <div class="stat-ico" style="background: rgba(13, 148, 136, 0.1); color: #0d9488; border-color: rgba(13, 148, 136, 0.2);">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
    </div>
    <div class="stat-lb">Aktif Sınıflar</div>
    <div class="stat-val"><%= metrics.classes %></div>
  </div>

  <div class="stat">
    <div class="stat-ico" style="background: rgba(99, 102, 241, 0.1); color: #6366f1; border-color: rgba(99, 102, 241, 0.2);">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
    </div>
    <div class="stat-lb">Aktif Öğrenciler</div>
    <div class="stat-val"><%= metrics.students %></div>
  </div>

  <div class="stat">
    <div class="stat-ico" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; border-color: rgba(245, 158, 11, 0.2);">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
    </div>
    <div class="stat-lb">Toplam Ödevler</div>
    <div class="stat-val"><%= metrics.homeworks %></div>
  </div>

  <div class="stat">
    <div class="stat-ico" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-color: rgba(16, 185, 129, 0.2);">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    </div>
    <div class="stat-lb">Alınan Yoklamalar</div>
    <div class="stat-val"><%= metrics.sessions %></div>
  </div>
</div>

<!-- Teacher Leaderboard / Highlights -->
<div style="display: grid; grid-template-columns: 1fr; gap: 20px; margin-bottom: 24px; @media(min-width: 768px) { grid-template-columns: 1fr 1fr; }">
  <!-- Top Homework Checker -->
  <div class="card" style="border-top: 4px solid #f59e0b;">
    <h2 class="card-title" style="font-size: 14px; margin-bottom: 12px; display: flex; align-items: center; gap: 6px;">
      <svg style="width: 18px; height: 18px; color: #f59e0b;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      En Çok Ödev Kontrol Eden
    </h2>
    <% if (topChecker) { %>
      <div style="display: flex; align-items: center; justify-content: space-between;">
        <div style="font-weight: 700; color: var(--text);"><%= topChecker.display_name %></div>
        <div style="font-size: 13px; color: var(--text2);"><span class="bdg bdg-warn" style="font-weight: 800; font-size: 12px;"><%= topChecker.check_count %> Ödev</span></div>
      </div>
    <% } else { %>
      <div style="font-size: 13px; color: var(--text3);">Henüz ödev kontrolü yapılmadı.</div>
    <% } %>
  </div>

  <!-- Top Attendance Taker -->
  <div class="card" style="border-top: 4px solid #10b981;">
    <h2 class="card-title" style="font-size: 14px; margin-bottom: 12px; display: flex; align-items: center; gap: 6px;">
      <svg style="width: 18px; height: 18px; color: #10b981;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      En Çok Yoklama Alan
    </h2>
    <% if (topTaker) { %>
      <div style="display: flex; align-items: center; justify-content: space-between;">
        <div style="font-weight: 700; color: var(--text);"><%= topTaker.display_name %></div>
        <div style="font-size: 13px; color: var(--text2);"><span class="bdg bdg-ok" style="font-weight: 800; font-size: 12px;"><%= topTaker.session_count %> Oturum</span></div>
      </div>
    <% } else { %>
      <div style="font-size: 13px; color: var(--text3);">Henüz yoklama oturumu alınmadı.</div>
    <% } %>
  </div>
</div>

<!-- Top Students Leaderboard -->
<div class="card" style="margin-bottom: 24px;">
  <h2 class="card-title" style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
    <svg style="width: 20px; height: 20px; color: #f59e0b;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
    En Başarılı Öğrenciler (En Çok Ödev Tamamlayanlar)
  </h2>
  <% if (topStudents.length === 0) { %>
    <div class="empty" style="padding: 24px 0;">
      <div class="empty-t" style="font-size: 13px;">Kayıt Bulunmamaktadır</div>
    </div>
  <% } else { %>
    <div class="lst">
      <% topStudents.forEach(function(s, index) { %>
        <div class="lst-it" style="cursor: default; padding: 12px 0;">
          <div class="lst-av" style="background: <%= index === 0 ? '#fef3c7' : (index === 1 ? '#f1f5f9' : '#fafaf9') %>; color: <%= index === 0 ? '#d97706' : '#475569' %>; font-weight: 800;">
            <%= index + 1 %>
          </div>
          <div class="lst-c">
            <div class="lst-t" style="font-size: 13px; font-weight: 700; color: var(--text);"><%= s.name %> <%= s.surname %></div>
            <div class="lst-s" style="font-size: 11px; color: var(--text2); margin-top: 2px;"><%= s.class_name %></div>
          </div>
          <div>
            <span class="bdg bdg-ok" style="font-size: 11px; font-weight: 800;"><%= s.completed_count %> Ödev Ezberledi</span>
          </div>
        </div>
        <% if (index < topStudents.length - 1) { %>
          <div style="border-bottom: 1px solid #f1f5f9;"></div>
        <% } %>
      <% }); %>
    </div>
  <% } %>
</div>

<!-- Personal Metrics of Logged-in Super Admin -->
<div class="card">
  <h2 class="card-title" style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
    <svg style="width: 20px; height: 20px; color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
    Kişisel Çalışma Raporum (Süper Admin)
  </h2>
  
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-top: 8px;">
    <div style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 12px; border-radius: 12px; text-align: center;">
      <div style="font-size: 20px; font-weight: 800; color: var(--text);"><%= personalStats.classes %></div>
      <div style="font-size: 11px; color: var(--text2); font-weight: 600; margin-top: 4px;">Kurduğum Sınıflar</div>
    </div>
    
    <div style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 12px; border-radius: 12px; text-align: center;">
      <div style="font-size: 20px; font-weight: 800; color: var(--text);"><%= personalStats.students %></div>
      <div style="font-size: 11px; color: var(--text2); font-weight: 600; margin-top: 4px;">Sınıflarımdaki Öğrenciler</div>
    </div>

    <div style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 12px; border-radius: 12px; text-align: center;">
      <div style="font-size: 20px; font-weight: 800; color: var(--text);"><%= personalStats.homeworks %></div>
      <div style="font-size: 11px; color: var(--text2); font-weight: 600; margin-top: 4px;">Verdiğim Ödevler</div>
    </div>

    <div style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 12px; border-radius: 12px; text-align: center;">
      <div style="font-size: 20px; font-weight: 800; color: var(--text);"><%= personalStats.sessions %></div>
      <div style="font-size: 11px; color: var(--text2); font-weight: 600; margin-top: 4px;">Aldığım Yoklamalar</div>
    </div>

    <div style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 12px; border-radius: 12px; text-align: center;">
      <div style="font-size: 20px; font-weight: 800; color: var(--text);"><%= personalStats.notes %></div>
      <div style="font-size: 11px; color: var(--text2); font-weight: 600; margin-top: 4px;">Yazdığım Ders Notları</div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
