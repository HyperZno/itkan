<%- include('../partials/header', { title: 'Notlar' }) %>
<% currentPage = 'siniflar'; %>

<div class="back" style="margin-bottom:16px">
  <a href="/sinif/<%= classData.id %>" class="btn btn-s btn-ico"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
  <div><h1 style="font-size:20px;font-weight:700">Öğretmen Notları</h1><span style="font-size:12px;color:var(--text2)"><%= classData.name %></span></div>
</div>

<div class="card sec">
  <h2 class="card-title">Yeni Not Ekle</h2>
  <form method="POST" action="/notlar/sinif/<%= classData.id %>/ekle">
    <div class="fg"><label class="fl">Notunuz</label><textarea name="content" class="fta" rows="4" placeholder="Diğer öğretmenler için not bırakın..." required></textarea></div>
    <button type="submit" class="btn btn-p btn-blk">Not Ekle</button>
  </form>
</div>

<div class="sec"><div class="sec-hdr"><h2 class="sec-t">Tüm Notlar</h2></div>
<% if (notes.length === 0) { %>
<div class="card" style="text-align:center;padding:40px 20px">
  <p style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:4px">Henüz Not Yok</p>
  <p style="font-size:13px;color:var(--text2)">Diğer öğretmenler için ilk notu sen bırak</p>
</div>
<% } else { %>
<% notes.forEach(function(n) { %>
<div class="nc">
  <div class="nc-hdr">
    <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
      <span class="nc-auth"><%= n.teacher_name %></span>
      <span style="font-size:11px;color:#a16207">•</span>
      <span class="nc-date"><%= new Date(n.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
    </div>
    <% if (n.created_by === currentUser.id || currentUser.role === 'super_admin') { %>
    <form method="POST" action="/notlar/<%= n.id %>/sil" style="margin:0"><button type="submit" class="btn btn-ghost btn-xs" style="color:#dc2626">Sil</button></form>
    <% } %>
  </div>
  <div class="nc-c"><%= n.content %></div>
</div>
<% }); %>
<% } %></div>

<%- include('../partials/footer') %>
