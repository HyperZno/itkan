<%- include('partials/header', { title: 'Ana Sayfa' }) %>
<% currentPage = 'dashboard'; %>

<div class="hdr"><h1>Ana Sayfa</h1><span class="hdr-sub"><%= new Date().toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) %></span></div>

<div class="stats">
  <a href="/siniflar" class="stat">
    <div class="stat-ico" style="background:#ccfbf1"><svg fill="none" stroke="#0a6e6a" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg></div>
    <div class="stat-lb">Sınıflar</div>
    <div class="stat-val"><%= classes.length %></div>
  </a>
  <a href="/sureler" class="stat">
    <div class="stat-ico" style="background:#d1fae5"><svg fill="none" stroke="#059669" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg></div>
    <div class="stat-lb">Sureler</div>
    <div class="stat-val">114</div>
  </a>
</div>

<% if (classes.length > 0) { %>
<div class="sec">
  <div class="sec-hdr"><h2 class="sec-t">Sınıfların</h2><a href="/siniflar" class="sec-lk">Tümünü Gör</a></div>
  <div class="card" style="padding:4px 16px">
    <% classes.slice(0, 5).forEach(function(c, i) { %>
    <a href="/sinif/<%= c.id %>" class="lst-it" style="padding:12px 0">
      <div class="lst-av" style="background:#ccfbf1;color:#0a6e6a;width:38px;height:38px;font-size:14px"><%= c.name.charAt(0) %></div>
      <div class="lst-c"><div class="lst-t"><%= c.name %></div><div class="lst-s"><%= c.student_count || 0 %> öğrenci</div></div>
      <svg class="lst-ch" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
    <% if (i < classes.slice(0, 5).length - 1) { %><div style="border-bottom:1px solid #f3f4f6"></div><% } %>
    <% }); %>
  </div>
</div>
<% } %>

<% if (classes.length === 0) { %>
<div class="card">
  <div class="empty">
    <div class="empty-ico"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg></div>
    <div class="empty-t">Henüz Sınıf Yok</div>
    <div class="empty-d">İlk sınıfını oluşturarak başla</div>
    <a href="/sinif-ekle" class="btn btn-p">Sınıf Oluştur</a>
  </div>
</div>
<% } %>

<!-- Floating Action Button for Announcement -->
<div class="fab-container" style="position: fixed; right: 20px; bottom: 76px; z-index: 100;">
  <button onclick="openAnnouncementModal()" style="display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; border-radius: 50%; background: var(--primary); color: #ffffff; border: none; box-shadow: 0 4px 14px rgba(99, 102, 241, 0.4); cursor: pointer; transition: all 0.2s; outline: none; padding: 0;" title="Yeni Duyuru Yayınla">
    <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
  </button>
</div>

<!-- Announcement Creation Modal -->
<div id="announcementModal" class="dev-modal" style="display: none; align-items: center; justify-content: center; z-index: 120;">
  <div class="dev-modal-content" style="max-width: 480px; width: 90%; margin: auto; animation: slideUp 0.3s ease; background: #ffffff; border: 1px solid var(--border); box-shadow: var(--shadow-lg); border-radius: 16px; padding: 20px;">
    <div class="dev-modal-header" style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px; margin-bottom: 16px;">
      <h3 style="display: flex; align-items: center; gap: 8px; font-size: 16px; font-weight: 800; color: var(--text); margin: 0;">
        <svg style="width: 20px; height: 20px; color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Yeni Duyuru Yayınla
      </h3>
      <button class="dev-close-btn" onclick="closeAnnouncementModal()" style="border: none; background: none; font-size: 20px; cursor: pointer; color: var(--text3);">&times;</button>
    </div>
    <div class="dev-modal-body" style="text-align: left;">
      <form method="POST" action="/duyurular/yayinla?redirect=/dashboard" style="margin: 0;">
        <div class="fg" style="margin-bottom: 16px;">
          <label style="font-weight: 700; font-size: 13px; color: var(--text2); display: block; margin-bottom: 6px;">Duyuru Başlığı</label>
          <input type="text" name="title" class="fi" placeholder="Duyuru başlığını girin" required autocomplete="off" style="width: 100%;">
        </div>
        <div class="fg" style="margin-bottom: 20px;">
          <label style="font-weight: 700; font-size: 13px; color: var(--text2); display: block; margin-bottom: 6px;">Duyuru İçeriği</label>
          <textarea name="content" class="fi" style="height: 120px; resize: none; font-family: inherit; width: 100%;" placeholder="Diğer öğretmenlere duyurmak istediğiniz metni buraya yazın..." required></textarea>
        </div>
        <button type="submit" class="btn btn-p btn-blk" style="font-weight: 800; font-size: 14px; width: 100%; height: 44px; display: flex; align-items: center; justify-content: center; gap: 8px;">
          <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          Yayınla ve Bildirim Gönder
        </button>
      </form>
    </div>
  </div>
</div>

<script>
function openAnnouncementModal() {
  var modal = document.getElementById('announcementModal');
  modal.style.display = 'flex';
}
function closeAnnouncementModal() {
  var modal = document.getElementById('announcementModal');
  modal.style.display = 'none';
}
</script>

<%- include('partials/footer') %>
