<%- include('../partials/header', { title: 'Ödev Ver' }) %>
<% currentPage = 'siniflar'; %>

<div class="back" style="margin-bottom:20px">
  <a href="/ogrenci/<%= student.id %>" class="btn btn-s btn-ico"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
  <div><h1 style="font-size:20px;font-weight:700;line-height:1.2">Ödev Ver</h1><span style="font-size:12px;color:var(--text2)"><%= student.name %> <%= student.surname %> • <%= student.class_name %></span></div>
</div>

<% if (typeof activeHomeworks !== 'undefined' && activeHomeworks.length > 0) { %>
  <div class="card" style="background: #fffbeb; border: 1px solid #fde68a; margin-bottom: 20px; display: flex; gap: 12px; align-items: flex-start; padding: 16px;">
    <div style="font-size: 20px; line-height: 1;">⚠️</div>
    <div>
      <h3 style="margin: 0; font-size: 14px; font-weight: 700; color: #b45309;">Aktif Ödev Uyarısı</h3>
      <p style="margin: 4px 0 0 0; font-size: 12px; color: #d97706; line-height: 1.5;">
        Bu öğrencinin henüz tamamlanmamış (çalışmakta olduğu) <strong><%= activeHomeworks.length %></strong> aktif ödevi bulunmaktadır. 
        Yeni ödev vermeden önce mevcut ödevi kontrol etmek isteyebilirsiniz:
      </p>
      <ul style="margin: 8px 0 0 0; padding-left: 20px; font-size: 12px; color: #d97706;">
        <% activeHomeworks.forEach(function(hw) { %>
          <li>
            <% if (hw.type === 'elifba') { %>
              Elifba: <%= hw.elifba_topic_text %>
            <% } else if (hw.type === 'ezber') { %>
              Ezber: <%= hw.elifba_topic_text %>
            <% } else { %>
              <%= hw.surah_name %> Suresi <%= hw.page_number ? '(S. ' + hw.page_number + ')' : '' %>
            <% } %>
            <% if (hw.due_date) { %>
              - Teslim Tarihi: <%= new Date(hw.due_date).toLocaleDateString('tr-TR') %>
            <% } %>
          </li>
        <% }); %>
      </ul>
      <div style="margin-top: 12px;">
        <a href="/ogrenci/<%= student.id %>" class="btn btn-sm" style="background: #b45309; color: #ffffff; border: none; font-size: 11px; padding: 4px 10px; border-radius: 6px; text-decoration: none;">
          Ödevleri Gör ve Kontrol Et ➔
        </a>
      </div>
    </div>
  </div>
<% } %>

<div class="card">
  <div style="display:flex;gap:8px;margin-bottom:20px">
    <button type="button" class="btn btn-p btn-sm" id="tabSurah" onclick="switchTab('surah')" style="flex:1">Sure</button>
    <button type="button" class="btn btn-s btn-sm" id="tabElifba" onclick="switchTab('elifba')" style="flex:1">Elifba</button>
    <button type="button" class="btn btn-s btn-sm" id="tabEzber" onclick="switchTab('ezber')" style="flex:1">Ezber</button>
  </div>

  <form method="POST" action="/odev/ogrenci/<%= student.id %>/ekle" id="homeworkForm">
    <input type="hidden" name="type" id="hwType" value="surah">

    <div id="surahSection">
      <div class="fg"><label class="fl">Sure Seç</label>
        <input type="text" id="surahSearchInput" class="fi" placeholder="Sure adı yazın veya seçin..." list="surahDatalist" oninput="onSurahInputChange()" autocomplete="off">
        <input type="hidden" name="surah_id" id="surahIdInput">
        <datalist id="surahDatalist">
          <% surahs.forEach(function(s) { %>
          <option value="<%= s.order_index %>. <%= s.name %>" data-id="<%= s.id %>"></option>
          <% }); %>
        </datalist>
      </div>
      <div class="flex-2">
        <div class="fg"><label class="fl">Sayfa No <span style="color:var(--text3);font-weight:400">(isteğe bağlı)</span></label><input type="text" name="page_number" class="fi" id="pageNumberInput" placeholder="Örn: 77"></div>
        <div class="fg"><label class="fl">Ayetler / Detay <span style="color:var(--text3);font-weight:400">(isteğe bağlı)</span></label><input type="text" name="page_detail" class="fi" id="pageDetailInput" placeholder="Örn: 3. ve 4. ayetler"></div>
      </div>
    </div>

    <div id="elifbaSection" style="display:none">
      <div class="fg"><label class="fl">Elifba Konusu / Sayfa</label>
        <input type="text" name="elifba_topic_text" class="fi" id="elifbaTopicInput" placeholder="Örn: Harfler, Sayfa 5 veya 10. Ders" autocomplete="off">
      </div>
    </div>

    <div id="ezberSection" style="display:none">
      <div class="fg"><label class="fl">Ezberlenecek Sure / Dua / Parça</label>
        <input type="text" name="ezber_topic_text" class="fi" id="ezberTopicInput" placeholder="Sure, dua, ezan veya kamet yazın ya da seçin..." list="ezberDatalist" autocomplete="off">
        <datalist id="ezberDatalist">
          <option value="Fâtiha Suresi"></option>
          <option value="Fil Suresi"></option>
          <option value="Kureyş Suresi"></option>
          <option value="Mâûn Suresi"></option>
          <option value="Kevser Suresi"></option>
          <option value="Kâfirûn Suresi"></option>
          <option value="Nasr Suresi"></option>
          <option value="Tebbet Suresi"></option>
          <option value="İhlâs Suresi"></option>
          <option value="Felak Suresi"></option>
          <option value="Nâs Suresi"></option>
          <option value="Duhâ Suresi"></option>
          <option value="İnşirâh Suresi"></option>
          <option value="Tîn Suresi"></option>
          <option value="Alak Suresi"></option>
          <option value="Kadr Suresi"></option>
          <option value="Beyyine Suresi"></option>
          <option value="Zilzâl Suresi"></option>
          <option value="Âdiyât Suresi"></option>
          <option value="Kâria Suresi"></option>
          <option value="Tekâsür Suresi"></option>
          <option value="Asr Suresi"></option>
          <option value="Hümeze Suresi"></option>
          <option value="Sübhaneke"></option>
          <option value="Ettehıyyatü"></option>
          <option value="Allahümme Salli"></option>
          <option value="Allahümme Barik"></option>
          <option value="Rabbena Atina"></option>
          <option value="Rabbenağfirli"></option>
          <option value="Kunut Duaları (Kunut 1)"></option>
          <option value="Kunut Duaları (Kunut 2)"></option>
          <option value="Ayet'el Kürsi"></option>
          <option value="Amenerrasulü"></option>
          <option value="Hüvallahüllezi"></option>
          <option value="Ezan"></option>
          <option value="Kamet"></option>
          <option value="Tesbihat"></option>
        </datalist>
      </div>
    </div>

    <div class="fg"><label class="fl">Teslim Tarihi <span style="color:var(--text3);font-weight:400">(isteğe bağlı)</span></label><input type="date" name="due_date" class="fi"></div>
    <div class="fg"><label class="fl">Not <span style="color:var(--text3);font-weight:400">(isteğe bağlı)</span></label><textarea name="notes" id="hwNotes" class="fta" rows="2" placeholder="Ödevle ilgili not..."></textarea></div>
    <button type="submit" class="btn btn-ok btn-blk">Ödevi Ver</button>
  </form>
</div>

<script>
function switchTab(type) {
  document.getElementById('hwType').value = type;
  document.getElementById('tabSurah').className = type === 'surah' ? 'btn btn-p btn-sm' : 'btn btn-s btn-sm';
  document.getElementById('tabElifba').className = type === 'elifba' ? 'btn btn-p btn-sm' : 'btn btn-s btn-sm';
  document.getElementById('tabEzber').className = type === 'ezber' ? 'btn btn-p btn-sm' : 'btn btn-s btn-sm';
  document.getElementById('surahSection').style.display = type === 'surah' ? 'block' : 'none';
  document.getElementById('elifbaSection').style.display = type === 'elifba' ? 'block' : 'none';
  document.getElementById('ezberSection').style.display = type === 'ezber' ? 'block' : 'none';
  if (type === 'surah') {
    document.getElementById('surahIdInput').required = true;
    document.getElementById('elifbaTopicInput').required = false;
    document.getElementById('ezberTopicInput').required = false;
    document.getElementById('hwNotes').value = "";
  } else if (type === 'elifba') {
    document.getElementById('surahIdInput').required = false;
    document.getElementById('elifbaTopicInput').required = true;
    document.getElementById('ezberTopicInput').required = false;
  } else if (type === 'ezber') {
    document.getElementById('surahIdInput').required = false;
    document.getElementById('elifbaTopicInput').required = false;
    document.getElementById('ezberTopicInput').required = true;
  }
}

function onSurahInputChange() {
  var input = document.getElementById('surahSearchInput');
  var val = input.value.trim().toLowerCase();
  var opts = document.getElementById('surahDatalist').options;
  var idInput = document.getElementById('surahIdInput');
  
  idInput.value = "";
  if (!val) return;
  
  for (var i = 0; i < opts.length; i++) {
    var optValue = opts[i].value;
    var optId = opts[i].getAttribute('data-id');
    
    var cleanOptValue = optValue.toLowerCase();
    var nameOnly = optValue.substring(optValue.indexOf(' ') + 1).toLowerCase();
    
    if (cleanOptValue === val || nameOnly === val) {
      idInput.value = optId;
      if (nameOnly === val) {
        input.value = optValue;
      }
      break;
    }
  }
}
</script>

<%- include('../partials/footer') %>
