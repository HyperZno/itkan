<%- include('../partials/header', { title: 'Ödevler' }) %>
<% currentPage = 'odevler'; %>

<div class="hdr">
  <h1>Öğrenci Ödevleri</h1>
  <span class="hdr-sub"><%= students.length %> kayıtlı öğrenci</span>
</div>

<div class="card" style="margin-bottom: 20px; padding: 16px;">
  <div style="display: flex; gap: 8px; flex-wrap: wrap;">
    <div style="position: relative; flex: 1;">
      <input type="text" id="studentSearch" class="fi" placeholder="Öğrenci adı veya sınıf ara..." oninput="filterStudents()" autocomplete="off">
    </div>
    <button type="button" class="btn btn-s btn-sm" id="btnFilterToday" onclick="toggleTodayFilter()" style="white-space: nowrap;">
      Bugün Teslim Olanlar
    </button>
  </div>
  <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px;">
    <select id="classFilterSelect" class="fi" style="flex: 1; min-width: 120px;" onchange="filterStudents()">
      <option value="">Tüm Sınıflar</option>
    </select>
    <select id="statusFilterSelect" class="fi" style="flex: 1; min-width: 120px;" onchange="filterStudents()">
      <option value="">Tüm Ödev Durumları</option>
      <option value="has_hw">Ödevi Olanlar</option>
      <option value="no_hw">Ödevi Olmayanlar</option>
      <option value="overdue">Ödevi Gecikenler</option>
    </select>
    <select id="typeFilterSelect" class="fi" style="flex: 1; min-width: 120px;" onchange="filterStudents()">
      <option value="">Tüm Ödev Tipleri</option>
      <option value="surah">Sure</option>
      <option value="elifba">Elifba</option>
      <option value="ezber">Ezber</option>
    </select>
  </div>
</div>

<div class="lst" id="studentList">
  <% if (students.length === 0) { %>
    <div class="card">
      <div class="empty">
        <div class="empty-ico">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        </div>
        <div class="empty-t">Öğrenci Bulunmamaktadır</div>
        <div class="empty-d">Ödev atamak için önce öğrenci ekleyin.</div>
        <a href="/ogrenci-ekle" class="btn btn-p">Öğrenci Ekle</a>
      </div>
    </div>
  <% } else { %>
    <% students.forEach(function(s) { %>
      <div class="card hw-st-card student-item" data-name="<%= s.name %> <%= s.surname %>" data-class="<%= s.class_name %>">
        <div class="hw-st-av">
          <%= s.name.charAt(0).toUpperCase() %>
        </div>
        <div class="hw-st-c">
          <div class="hw-st-n"><%= s.name %> <%= s.surname %></div>
          <div class="hw-st-cl"><%= s.class_name %></div>
          
          <div style="margin-top: 10px;">
            <% if (s.homeworks && s.homeworks.length > 0) { %>
              <div class="hw-header" style="font-size: 13px; font-weight: 600; color: var(--text2); margin-bottom: 4px;">Aktif Ödevler:</div>
              <% s.homeworks.forEach(function(hw) { %>
                <div class="hw-item" data-type="<%= hw.type %>" data-due-date="<%= hw.due_date ? new Date(hw.due_date).toISOString().split('T')[0] : '' %>" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; font-size: 12px; margin-bottom: 6px; background: #f8fafc; padding: 6px 10px; border-radius: 8px; border: 1px solid var(--border)">
                  <span>
                    <% if (hw.type === 'elifba') { %>
                      📖 Elifba: <%= hw.elifba_topic_text || (hw.lesson_number ? hw.lesson_number + '. ' + hw.elifba_topic_name : '') %>
                      <% if (hw.elifba_url) { %>
                        <a href="<%= hw.elifba_url %>" target="_blank" class="sec-lk" style="font-size: 10px; font-weight: 700; text-decoration: underline; margin-left: 6px;">Çalış ➔</a>
                      <% } %>
                    <% } else if (hw.type === 'ezber') { %>
                      📖 Ezber: <%= hw.elifba_topic_text %>
                    <% } else { %>
                      📖 <%= hw.surah_name %><%= hw.page_number ? ' - S. ' + hw.page_number + (hw.page_detail ? ' (' + hw.page_detail + ')' : '') : (hw.start_ayah ? ' (' + hw.start_ayah + '-' + hw.end_ayah + '. ayet)' : '') %>
                      <% if (hw.translation_option === 'mealiyle') { %>
                        <span class="bdg bdg-info" style="font-size: 8px; padding: 1px 4px; line-height: 1; display: inline-block; margin-left: 4px;">Mealiyle</span>
                      <% } else if (hw.translation_option === 'sadece_meal') { %>
                        <span class="bdg bdg-warn" style="font-size: 8px; padding: 1px 4px; line-height: 1; display: inline-block; margin-left: 4px;">Sadece Meal</span>
                      <% } %>
                    <% } %>
                  </span>
                  <span class="bdg <%= hw.status === 'completed' ? 'bdg-ok' : (hw.status === 'gelmedi' || hw.status === 'yapmadi' ? 'bdg-err' : 'bdg-warn') %>" style="padding: 2px 8px; font-size: 10px;">
                    <%= hw.status === 'completed' ? (hw.type === 'ezber' ? 'Ezberledi' : 'Yaptı') : (hw.status === 'gelmedi' ? 'Gelmedi' : (hw.status === 'yapmadi' ? 'Yapmadı' : 'Çalışıyor')) %>
                  </span>
                </div>
              <% }); %>
            <% } else { %>
              <span class="bdg bdg-gray" style="font-size: 11px;">Aktif Ödev Yok</span>
            <% } %>
          </div>
        </div>
        
        <div class="hw-st-r">
          <a href="/ogrenci/<%= s.id %>" class="btn btn-s btn-sm">Görüntüle</a>
          <a href="/odev/ogrenci/<%= s.id %>/ekle" class="btn btn-p btn-sm" style="gap:4px">
            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
            Ödev Ver
          </a>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>

<script>
var showOnlyToday = false;

function toggleTodayFilter() {
  showOnlyToday = !showOnlyToday;
  var btn = document.getElementById('btnFilterToday');
  if (showOnlyToday) {
    btn.className = 'btn btn-p btn-sm';
  } else {
    btn.className = 'btn btn-s btn-sm';
  }
  filterStudents();
}

function turkishNormalize(str) {
  if (!str) return '';
  return str.toLocaleLowerCase('tr-TR')
    .replace(/ı/g, 'i')
    .replace(/ğ/g, 'g')
    .replace(/ü/g, 'u')
    .replace(/ş/g, 's')
    .replace(/ö/g, 'o')
    .replace(/ç/g, 'c')
    .replace(/i̇/g, 'i');
}

function filterStudents() {
  var q = turkishNormalize(document.getElementById('studentSearch').value.trim());
  var classFilter = document.getElementById('classFilterSelect').value.trim();
  var statusFilter = document.getElementById('statusFilterSelect').value;
  var typeFilter = document.getElementById('typeFilterSelect').value;
  
  var items = document.querySelectorAll('.student-item');
  
  var localToday = new Date();
  var offset = localToday.getTimezoneOffset();
  localToday = new Date(localToday.getTime() - (offset * 60 * 1000));
  var todayStr = localToday.toISOString().split('T')[0];

  items.forEach(function(item) {
    var name = turkishNormalize(item.getAttribute('data-name') || '');
    var clsRaw = item.getAttribute('data-class') || '';
    var cls = turkishNormalize(clsRaw);
    
    // 1. Search Query Match
    var matchesSearch = name.includes(q) || cls.includes(q);
    
    // 2. Class Filter Match
    var matchesClass = (classFilter === '' || clsRaw.trim() === classFilter);
    
    var hwItems = item.querySelectorAll('.hw-item');
    
    // 3. Status Filter Match
    var matchesStatus = true;
    if (statusFilter === 'has_hw') {
      matchesStatus = (hwItems.length > 0);
    } else if (statusFilter === 'no_hw') {
      matchesStatus = (hwItems.length === 0);
    } else if (statusFilter === 'overdue') {
      var hasOverdue = false;
      hwItems.forEach(function(hw) {
        var due = hw.dataset.dueDate;
        if (due && due < todayStr) {
          hasOverdue = true;
        }
      });
      matchesStatus = hasOverdue;
    }
    
    // 4. Type Filter Match
    var matchesType = true;
    if (typeFilter !== '') {
      var hasType = false;
      hwItems.forEach(function(hw) {
        if (hw.dataset.type === typeFilter) {
          hasType = true;
        }
      });
      matchesType = hasType;
    }
    
    // 5. Today Filter Match & individual item visibility
    var hasHwDueToday = false;
    var visibleHwCount = 0;
    
    hwItems.forEach(function(hw) {
      var dueDate = hw.dataset.dueDate;
      var hwType = hw.dataset.type;
      
      var hwMatchesType = (typeFilter === '' || hwType === typeFilter);
      var hwMatchesToday = (!showOnlyToday || dueDate === todayStr);
      
      if (hwMatchesType && hwMatchesToday) {
        hw.style.display = 'flex';
        if (dueDate === todayStr) {
          hasHwDueToday = true;
        }
        visibleHwCount++;
      } else {
        hw.style.display = 'none';
      }
    });
    
    var header = item.querySelector('.hw-header');
    if (header) {
      header.style.display = visibleHwCount > 0 ? 'block' : 'none';
    }

    var matchesToday = (!showOnlyToday || hasHwDueToday);
    
    var shouldBeVisible = matchesSearch && matchesClass && matchesStatus && matchesType && matchesToday;
    if (shouldBeVisible) {
      item.style.display = 'flex';
    } else {
      item.style.display = 'none';
    }
  });
}

document.addEventListener('DOMContentLoaded', function() {
  var classSelect = document.getElementById('classFilterSelect');
  var classes = new Set();
  document.querySelectorAll('.student-item').forEach(function(item) {
    var clsName = item.getAttribute('data-class');
    if (clsName) classes.add(clsName.trim());
  });
  var sortedClasses = Array.from(classes).sort();
  sortedClasses.forEach(function(cls) {
    var opt = document.createElement('option');
    opt.value = cls;
    opt.textContent = cls;
    classSelect.appendChild(opt);
  });
});
</script>

<%- include('../partials/footer') %>
